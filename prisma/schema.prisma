generator client {
  provider = "prisma-client-js"
}

datasource db1 {
  provider = "postgresql"
  url = env("DATABASE_URL1")
}

datasource db2 {
  provider = "postgresql"
  url = env("DATABASE_URL2")
}

datasource db3 {
  provider = "postgresql"
  url = env("DATABASE_URL3")
}

// ========== DB1: users, posts, follows ==========
model User {
  id Int @id @default(autoincrement())
  email String @unique
  password String
  username String @unique
  createdAt DateTime @default(now())
  monetizedAt DateTime?
  freeFarmingStopped Boolean @default(false)
  freeCredits Float @default(1500)
  cashBalance Float @default(0)
  referralCount Int @default(0)
  posts_count Int @default(0)
  followers_count Int @default(0)
  following_count Int @default(0)

  posts Media_post[]
  comments Comment[]
  likes Like[]
  pointsLedger PointsLedger[]
  stories Story[]
  chapters Chapter[]

  @@map("users")
  @@datasource(name: "db", url: env("DATABASE_URL1"))
}

model Media_post {
  id Int @id @default(autoincrement())
  userId Int
  type String // video, image, text
  caption String?
  b2Key String?
  b2Shard Int // 0,1,2 for B2_A/B/C routing
  status String @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  likes Like[]
  comments Comment[]

  @@map("media_posts")
  @@datasource(name: "db", url: env("DATABASE_URL1"))
}

model Follow {
  id Int @id @default(autoincrement())
  followerId Int
  followingId Int
  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
  @@datasource(name: "db", url: env("DATABASE_URL1"))
}

// ========== DB2: likes, comments, referrals, stories ==========
model Like {
  id Int @id @default(autoincrement())
  postId Int
  userId Int
  createdAt DateTime @default(now())

  post Media_post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("likes")
  @@datasource(name: "db", url: env("DATABASE_URL2"))
}

model Comment {
  id Int @id @default(autoincrement())
  postId Int
  userId Int
  text String
  createdAt DateTime @default(now())

  post Media_post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("comments")
  @@datasource(name: "db", url: env("DATABASE_URL2"))
}

model Story {
  id Int @id @default(autoincrement())
  userId Int
  title String
  description String?
  type String @default("story") // story, novel
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  chapters Chapter[]

  @@map("stories")
  @@datasource(name: "db", url: env("DATABASE_URL2"))
}

model Chapter {
  id Int @id @default(autoincrement())
  storyId Int
  userId Int
  title String
  content String
  chapterNumber Int
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("chapters")
  @@datasource(name: "db", url: env("DATABASE_URL2"))
}

model Referral {
  id Int @id @default(autoincrement())
  referrerId Int
  referredId Int
  createdAt DateTime @default(now())
  completed Boolean @default(false) // true when ref hits 1000pts

  @@unique([referrerId, referredId])
  @@map("referrals")
  @@datasource(name: "db", url: env("DATABASE_URL2"))
}

// ========== DB3: points ledger only ==========
model PointsLedger {
  id Int @id @default(autoincrement())
  userId Int
  amount Float
  type String // view, like, comment, read_chapter, read_story, referral, deposit
  walletType String // free, cash
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("points_ledger")
  @@datasource(name: "db", url: env("DATABASE_URL3"))
}
