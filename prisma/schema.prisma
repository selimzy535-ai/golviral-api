generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ========== MODELS ==========
model User {
  id String @id @db.VarChar(16)
  username String @unique @db.VarChar(50)
  email String @unique @db.VarChar(100)
  password String @db.VarChar(255)
  role String @default("user") @db.VarChar(10)
  freeCredits Float @default(1500)
  cashBalance Float @default(0)
  monetizeFlag Boolean @default(false)
  freeFarmingStopped Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
  comments Comment[]
  ledgers PointsLedger[]
  payouts PayoutQueue[]
  deposits Deposit[] // Added relation for sharding

  // Follow relations
  followers Follow[] @relation("Followers")
  following Follow[] @relation("Following")

  // Referral relations
  referralsMade Referral[] @relation("Referrer")
  referralReceived Referral? @relation("Referee")

  @@index([email])
  @@index([username])
  @@index([monetizeFlag])
}

model Deposit {
  id String @id @default(cuid())
  userId String @db.VarChar(16) // FIX: Must match User.id length for sharding
  amountNaira Int
  points Int
  token String @unique // Used to prevent direct /verify spam
  reference String @unique @default("") // Selar tx_ref. Prevents replay attacks
  status String @default("PENDING") // PENDING, SUCCESS, FAILED, EXPIRED
  createdAt DateTime @default(now())
  expiresAt DateTime // 30min lock after /init

  user User @relation(fields: [userId], references: [id], onDelete: Cascade) // FIX: Required for Admin include

  @@index([userId])
  @@index([token])
  @@index([reference])
  @@index([status])
  @@index([createdAt])
}

model Post {
  id String @id @db.VarChar(16)
  userId String @db.VarChar(16)
  type String @default("reel") @db.VarChar(15) // reel, novel, story
  title String @default("") @db.Text
  content String @default("") @db.Text
  mediaUrl String @db.Text // B2 key
  thumbnailUrl String @db.Text // B2 key
  status String @db.VarChar(20) // PRE_UPLOAD, ACTIVE, REJECTED
  b2Shard Int @default(0) // 0, 1, 2 for B2 routing

  score Float @default(0)
  likes Int @default(0)
  comments Int @default(0) // counter cache
  views Int @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentsRel Comment[] // 1:N for fetching

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([score])
  @@index([createdAt])
}

model Comment {
  id String @id @default(cuid())
  postId String @db.VarChar(16)
  userId String @db.VarChar(16)
  text String @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}

model PointsLedger {
  id Int @id @default(autoincrement())
  userId String @db.VarChar(16)
  amount Float
  type String @db.VarChar(10) // FREE, CASH
  action String @db.VarChar(30) // LIKE, COMMENT, VIEW_REEL, READ_NOVEL, READ_STORY, REFERRAL_BONUS, DEPOSIT
  referenceId String @db.VarChar(64) // postId, tx_ref, etc
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Referral {
  id String @id @default(uuid())
  referrerId String @db.VarChar(16)
  refereeId String @unique @db.VarChar(16)
  status String @db.VarChar(20) // PENDING, QUALIFIED
  createdAt DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee User @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([status])
  @@index([createdAt])
}

model PayoutQueue {
  id String @id @db.VarChar(16)
  userId String @db.VarChar(16)
  amountPoints Float
  routingTarget String @db.VarChar(50) // BANK, USDT, etc
  targetDetails String @db.Text // Account number, wallet addr
  status String @db.VarChar(20) // PENDING, APPROVED, REJECTED
  reason String? @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Follow {
  id String @id @default(cuid())
  followerId String @db.VarChar(16)
  followingId String @db.VarChar(16)
  createdAt DateTime @default(now())

  follower User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([createdAt])
}
