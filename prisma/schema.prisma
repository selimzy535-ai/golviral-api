datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String         @id @db.VarChar(16)
  username           String         @unique @db.VarChar(50)
  email              String         @unique @db.VarChar(100)
  password           String         @db.VarChar(255)
  freeCredits        Float          @default(1500)
  cashBalance        Float          @default(0)
  monetizeFlag       Boolean        @default(false)
  freeFarmingStopped Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  posts              Post[]
  ledgers            PointsLedger[]
  payouts            PayoutQueue[]

  @@index([email])
  @@index([monetizeFlag])
}

model Post {
  id           String   @id @db.VarChar(16)
  userId       String   @db.VarChar(16)
  mediaUrl     String   @db.Text
  thumbnailUrl String   @db.Text
  status       String   @db.VarChar(20) // PRE_UPLOAD, ACTIVE, REJECTED
  b2Shard      Int      @default(0)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PointsLedger {
  id          Int      @id @default(autoincrement())
  userId      String   @db.VarChar(16)
  amount      Float
  type        String   @db.VarChar(10) // FREE, CASH
  action      String   @db.VarChar(30) // LIKE, COMMENT, VIEW_REEL, READ_NOVEL, etc.
  referenceId String   @db.VarChar(64)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Referral {
  id         String   @id @default(uuid())
  referrerId String   @db.VarChar(16)
  refereeId  String   @unique @db.VarChar(16)
  status     String   @db.VarChar(20) // PENDING, QUALIFIED
  createdAt  DateTime @default(now())

  @@index([referrerId])
  @@index([status])
}

model PayoutQueue {
  id            String   @id @db.VarChar(16)
  userId        String   @db.VarChar(16)
  amountPoints  Float
  routingTarget String   @db.VarChar(50)
  targetDetails String   @db.Text
  status        String   @db.VarChar(20) // PENDING, APPROVED, REJECTED
  reason        String?  @db.Text
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
