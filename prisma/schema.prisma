generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ========== MODELS ==========
model User {
  id String @id @db.VarChar(16)
  username String @unique @db.VarChar(50)
  email String @unique @db.VarChar(100)
  password String @db.VarChar(255)
  role String @default("user") @db.VarChar(10)
  freeCredits Float @default(1500)
  cashBalance Float @default(0)
  monetizeFlag Boolean @default(false)
  freeFarmingStopped Boolean @default(false)
  isVerified Boolean @default(false) // NEW: For DM unlock badge
  dmUnlocked Boolean @default(false) // NEW: For DM gate

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
  comments Comment[]
  ledgers PointsLedger[]
  payouts PayoutQueue[]
  deposits Deposit[]
  messagesSent Message[] @relation("SentMessages") // NEW
  messagesReceived Message[] @relation("ReceivedMessages") // NEW
  gifts Gift[] // NEW

  // Follow relations
  followers Follow[] @relation("Followers")
  following Follow[] @relation("Following")

  // Referral relations
  referralsMade Referral[] @relation("Referrer")
  referralReceived Referral? @relation("Referee")

  @@index([email])
  @@index([username])
  @@index([monetizeFlag])
}

model Deposit {
  id String @id @default(cuid())
  userId String @db.VarChar(16)
  amountNaira Int
  points Int
  token String @unique
  reference String @unique @default("")
  status String @default("PENDING")
  meta String @default("DEPOSIT") @db.VarChar(50) // NEW: DEPOSIT, DM_UNLOCK, GIFT_RUBY
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([reference])
  @@index([status])
  @@index([createdAt])
}

model Post {
  id String @id @db.VarChar(16)
  userId String @db.VarChar(16)
  type String @default("reel") @db.VarChar(15)
  title String @default("") @db.Text
  content String @default("") @db.Text
  mediaUrl String @db.Text
  thumbnailUrl String @db.Text
  status String @db.VarChar(20)
  b2Shard Int @default(0)

  score Float @default(0)
  likes Int @default(0)
  comments Int @default(0)
  views Int @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentsRel Comment[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([score])
  @@index([createdAt])
}

model Comment {
  id String @id @default(cuid())
  postId String @db.VarChar(16)
  userId String @db.VarChar(16)
  text String @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}

model PointsLedger {
  id Int @id @default(autoincrement())
  userId String @db.VarChar(16)
  amount Float
  type String @db.VarChar(10)
  action String @db.VarChar(30)
  referenceId String @db.VarChar(64)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Referral {
  id String @id @default(uuid())
  referrerId String @db.VarChar(16)
  refereeId String @unique @db.VarChar(16)
  status String @db.VarChar(20)
  createdAt DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee User @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([status])
  @@index([createdAt])
}

model PayoutQueue {
  id String @id @db.VarChar(16)
  userId String @db.VarChar(16)
  amountPoints Float
  routingTarget String @db.VarChar(50)
  targetDetails String @db.Text
  status String @db.VarChar(20)
  reason String? @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Follow {
  id String @id @default(cuid())
  followerId String @db.VarChar(16)
  followingId String @db.VarChar(16)
  createdAt DateTime @default(now())

  follower User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([createdAt])
}

// ========== NEW MODELS FOR V4.6 ==========
model Message {
  id String @id @db.VarChar(16)
  senderId String @db.VarChar(16)
  receiverId String @db.VarChar(16)
  text String @db.Text
  createdAt DateTime @default(now())

  sender User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Gift {
  id String @id @db.VarChar(16)
  buyerId String @db.VarChar(16)
  giftType String @db.VarChar(20) // RUBY, GOLD, DIAMOND
  price Int // NGN
  pointsPerGift Int
  giftsSent Int @default(0)
  giftsTotal Int @default(100)
  expiresAt DateTime
  createdAt DateTime @default(now())

  buyer User @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([expiresAt])
}
