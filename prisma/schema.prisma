datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Express overrides this at runtime using DATABASE_URL_1, _2, _3
}

generator client {
  provider = "prisma-client-js"
}

enum WalletType {
  FREE
  CASH
}

enum ActionType {
  LIKE
  COMMENT
  VIEW_REEL
  READ_NOVEL
  READ_STORY
  REFERRAL_BONUS
}

enum Status {
  PENDING
  QUALIFIED
  APPROVED
  REJECTED
  ACTIVE
  PENDING_WORKER
}

model User {
  id                 String         @id // Generated as hex via crypto.randomBytes(8)
  username           String
  email              String         @unique
  password           String
  freeCredits        Float          @default(1500)
  cashBalance        Float          @default(0)
  monetizeFlag       Boolean        @default(false)
  freeFarmingStopped Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  // Relations
  posts              Post[]
  pointsLedger       PointsLedger[]
  payouts            PayoutQueue[]
  referralsAsReferrer Referral[]    @relation("ReferrerRelation")
  referralsAsReferee  Referral[]    @relation("RefereeRelation")

  @@index([email])
}

model Post {
  id        String   @id // Generated as hex via crypto.randomBytes(8)
  userId    String
  mediaUrl  String // Maps to the B2 Object Key
  status    Status   @default(PENDING_WORKER)
  b2Shard   Int // Tracks getShardIndex(postId)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt]) // Used by the 15-day auto-delete cron
}

model PointsLedger {
  id          String     @id @default(uuid())
  userId      String
  amount      Float
  type        WalletType
  action      ActionType
  referenceId String     @default("") // Holds postId or contentId
  createdAt   DateTime   @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Referral {
  id         String   @id @default(uuid())
  referrerId String
  refereeId  String   @unique
  status     Status   @default(PENDING)
  createdAt  DateTime @default(now())

  // Relations
  referrer User @relation("ReferrerRelation", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("RefereeRelation", fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([referrerId, status])
}

model PayoutQueue {
  id           String   @id @default(uuid())
  userId       String
  amountPoints Float
  status       Status   @default(PENDING)
  reason       String? // Populated on rejection
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}
